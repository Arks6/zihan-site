<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>蘇子涵｜Zihan Su</title>
  <meta name="description" content="蘇子涵｜資訊管理系大一學生的一頁式個人網站。用數位工具整理資訊，也把閱讀、料理與日常美感，慢慢寫成自己的風格。" />
  <meta name="theme-color" content="#f5efe7" />
  <meta property="og:title" content="蘇子涵｜Zihan Su" />
  <meta property="og:description" content="資訊管理系大一學生的一頁式個人網站。理性整理資訊，也溫柔地記錄日常。" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="og-cover.jpg" />
  <link rel="icon" type="image/svg+xml" href='data:image/svg+xml;utf8,
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
    <defs>
      <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
        <stop stop-color="%23e8d6c5"/>
        <stop offset="1" stop-color="%23d5ddcf"/>
      </linearGradient>
    </defs>
    <rect width="128" height="128" rx="30" fill="url(%23g)"/>
    <text x="64" y="78" text-anchor="middle" font-size="56" font-family="Georgia, serif" fill="%23584235">子</text>
  </svg>' />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Serif+TC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#f5efe7;
      --bg-deep:#efe7de;
      --paper:rgba(255,255,255,.76);
      --paper-strong:rgba(255,255,255,.88);
      --ink:#2f2925;
      --muted:#6d655f;
      --line:rgba(98,80,64,.14);
      --line-strong:rgba(98,80,64,.22);
      --warm:#b88e69;
      --warm-deep:#875f41;
      --sage:#7d8b79;
      --soft:#d9d1c8;
      --shadow:0 22px 60px rgba(70,48,27,.08);
      --shadow-soft:0 12px 28px rgba(70,48,27,.06);
      --radius-xl:34px;
      --radius-lg:24px;
      --radius-md:18px;
      --maxw:1180px;
      --dock:76px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      color:var(--ink);
      background:
        radial-gradient(circle at 0% 0%, rgba(184,142,105,.14), transparent 22%),
        radial-gradient(circle at 100% 18%, rgba(125,139,121,.14), transparent 20%),
        linear-gradient(180deg, #f8f3ed 0%, #f2ebe3 100%);
      font-family:"Inter","Noto Sans TC",sans-serif;
      line-height:1.82;
      letter-spacing:.01em;
    }
    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background-image:
        linear-gradient(rgba(255,255,255,.46) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.46) 1px, transparent 1px);
      background-size:28px 28px;
      opacity:.22;
      mask-image:linear-gradient(to bottom, rgba(0,0,0,.42), rgba(0,0,0,.04));
    }
    a{color:inherit;text-decoration:none}
    img{display:block;max-width:100%}
    .container{width:min(calc(100% - 32px), var(--maxw)); margin:0 auto}
    .progress{
      position:fixed; top:0; left:0; z-index:80; height:3px; width:var(--progress,0%);
      background:linear-gradient(90deg,var(--warm),var(--sage)); box-shadow:0 0 18px rgba(184,142,105,.4)
    }
    .site-header{
      position:sticky; top:0; z-index:70; backdrop-filter:blur(16px);
      background:rgba(245,239,231,.78); border-bottom:1px solid rgba(98,80,64,.08);
    }
    .header-inner{display:flex; align-items:center; justify-content:space-between; gap:18px; padding:14px 0}
    .brand{display:flex; align-items:center; gap:12px; min-width:0}
    .brand-mark{
      width:46px; height:46px; border-radius:15px; display:grid; place-items:center;
      background:linear-gradient(135deg, rgba(184,142,105,.24), rgba(125,139,121,.22));
      border:1px solid rgba(98,80,64,.12); box-shadow:var(--shadow-soft);
      font-family:"Noto Serif TC",serif; font-size:1.1rem; font-weight:700;
    }
    .brand-name{font-size:.98rem; font-weight:700}
    .brand-sub{color:var(--muted); font-size:.82rem}
    .nav{display:flex; align-items:center; gap:8px; flex-wrap:wrap; justify-content:flex-end}
    .nav a{
      padding:10px 14px; border-radius:999px; color:var(--muted); font-size:.94rem;
      transition:.2s ease; border:1px solid transparent;
    }
    .nav a:hover,.nav a.active{
      color:var(--ink); background:rgba(255,255,255,.74); border-color:rgba(98,80,64,.10); box-shadow:var(--shadow-soft)
    }

    .hero{padding:52px 0 28px}
    .hero-shell{display:grid; grid-template-columns:minmax(0,1.1fr) minmax(300px,.9fr); gap:24px; align-items:stretch}
    .glass{
      background:var(--paper); border:1px solid rgba(98,80,64,.12); box-shadow:var(--shadow); backdrop-filter:blur(8px)
    }
    .hero-card{padding:36px; border-radius:var(--radius-xl); position:relative; overflow:hidden}
    .hero-card::after{
      content:""; position:absolute; right:-50px; bottom:-72px; width:220px; height:220px; border-radius:50%;
      background:radial-gradient(circle, rgba(184,142,105,.18), transparent 70%); pointer-events:none
    }
    .eyebrow{
      display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px;
      background:rgba(255,255,255,.74); color:var(--muted); border:1px solid rgba(98,80,64,.10);
      font-size:.82rem; letter-spacing:.05em;
    }
    .dot{width:8px; height:8px; border-radius:50%; background:linear-gradient(135deg,var(--warm),var(--sage))}
    h1,h2,h3,h4,p{margin:0}
    h1{
      margin-top:18px; font-family:"Noto Serif TC",serif; font-size:clamp(2.5rem,6vw,4.8rem);
      line-height:1.14; letter-spacing:.02em
    }
    .hero-subtitle{margin-top:20px; font-size:1.08rem; color:#4d443d; max-width:34em}
    .hero-note{margin-top:14px; color:var(--muted); max-width:39em}
    .hero-actions{display:flex; flex-wrap:wrap; gap:12px; margin-top:28px}
    .button,.ghost-button,.copy-button,.mini-button{
      display:inline-flex; align-items:center; justify-content:center; gap:8px; min-height:52px; padding:0 20px;
      border-radius:999px; border:1px solid transparent; font-weight:600; cursor:pointer; transition:.22s ease; font-size:.97rem
    }
    .button{color:#fff; background:linear-gradient(135deg,var(--warm-deep),var(--warm)); box-shadow:0 16px 30px rgba(127,92,63,.20)}
    .button:hover{transform:translateY(-1px)}
    .ghost-button,.copy-button,.mini-button{
      background:rgba(255,255,255,.68); color:var(--ink); border-color:rgba(98,80,64,.12)
    }
    .ghost-button:hover,.copy-button:hover,.mini-button:hover{background:rgba(255,255,255,.94)}
    .hero-chips{display:flex; flex-wrap:wrap; gap:10px; margin-top:28px}
    .chip{
      padding:9px 14px; border-radius:999px; font-size:.88rem; color:var(--muted);
      background:rgba(255,255,255,.68); border:1px solid rgba(98,80,64,.10)
    }
    .stat-row{display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:12px; margin-top:24px}
    .stat{
      padding:18px; border-radius:20px; background:rgba(255,255,255,.70); border:1px solid rgba(98,80,64,.10)
    }
    .stat strong{display:block; font-size:1.15rem}
    .stat span{display:block; margin-top:4px; color:var(--muted); font-size:.88rem}

    .photo-card{
      border-radius:var(--radius-xl); padding:16px; position:relative; overflow:hidden
    }
    .photo-card::before{
      content:""; position:absolute; inset:16px 16px auto auto; width:150px; height:150px; border-radius:50%;
      background:radial-gradient(circle, rgba(125,139,121,.22), transparent 66%); pointer-events:none
    }
    .photo-frame{
      position:relative; border-radius:26px; overflow:hidden; aspect-ratio:4 / 5;
      border:1px solid rgba(98,80,64,.10);
      background:linear-gradient(180deg, rgba(184,142,105,.12), rgba(125,139,121,.14))
    }
    .photo-frame img{width:100%; height:100%; object-fit:cover; object-position:center 18%}
    .photo-panel{
      position:absolute; inset:auto 16px 16px 16px; padding:18px;
      border-radius:20px; background:linear-gradient(180deg, rgba(47,41,37,0.08), rgba(47,41,37,.78));
      color:#fff; backdrop-filter:blur(12px)
    }
    .photo-panel .title{font-size:1.06rem; font-weight:700}
    .photo-panel .sub{margin-top:6px; color:rgba(255,255,255,.86); font-size:.92rem}
    .panel-tags{display:flex; flex-wrap:wrap; gap:8px; margin-top:12px}
    .panel-tags span{
      padding:7px 10px; border-radius:999px; font-size:.8rem;
      background:rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.18)
    }
    .floating-note{
      position:absolute; top:24px; left:24px; padding:12px 14px; border-radius:18px;
      background:rgba(255,255,255,.82); border:1px solid rgba(98,80,64,.10); box-shadow:var(--shadow-soft); max-width:180px
    }
    .floating-note small{display:block; color:var(--sage); font-weight:700; letter-spacing:.08em; text-transform:uppercase; font-size:.72rem}
    .floating-note p{margin-top:4px; font-size:.86rem; color:#4f4640; line-height:1.55}

    section{padding:36px 0}
    .section-head{max-width:780px; margin-bottom:22px}
    .section-kicker{
      color:var(--sage); font-size:.82rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase
    }
    .section-head h2{margin-top:8px; font-family:"Noto Serif TC",serif; font-size:clamp(1.8rem,3vw,2.5rem)}
    .section-head p{margin-top:10px; color:var(--muted)}

    .story-grid,.skills-grid,.interests-grid,.process-grid,.portfolio-grid,.snapshot-grid,.contact-grid,.footer-grid{
      display:grid; gap:18px
    }
    .story-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
    .skills-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
    .interests-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
    .process-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
    .portfolio-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
    .snapshot-grid{grid-template-columns:2fr 1.1fr}
    .contact-grid{grid-template-columns:1.2fr .8fr}
    .card{padding:24px; border-radius:var(--radius-lg)}
    .card h3{font-size:1.08rem}
    .card p{margin-top:10px; color:var(--muted)}
    .mini-kicker{
      display:inline-flex; padding:7px 10px; border-radius:999px; font-size:.76rem;
      background:rgba(255,255,255,.72); border:1px solid rgba(98,80,64,.10); color:var(--sage); font-weight:700; letter-spacing:.06em; text-transform:uppercase
    }
    .story-list{margin-top:12px; padding-left:1rem; color:var(--muted)}
    .story-list li+li{margin-top:8px}
    .story-value{margin-top:18px; padding-top:18px; border-top:1px solid rgba(98,80,64,.10); color:#514842; font-size:.92rem}

    .skill-top{display:flex; align-items:center; justify-content:space-between; gap:12px}
    .skill-index{
      width:42px; height:42px; border-radius:14px; display:grid; place-items:center;
      background:linear-gradient(135deg, rgba(184,142,105,.22), rgba(125,139,121,.22));
      border:1px solid rgba(98,80,64,.10); font-weight:700
    }

    .interest-card{position:relative; overflow:hidden}
    .interest-card::after{
      content:""; position:absolute; right:-40px; bottom:-40px; width:120px; height:120px; border-radius:50%;
      background:radial-gradient(circle, rgba(184,142,105,.14), transparent 68%); pointer-events:none
    }

    .process-step{
      position:relative; padding-top:18px
    }
    .process-step::before{
      content:""; position:absolute; top:0; left:0; width:48px; height:4px; border-radius:999px; background:linear-gradient(90deg,var(--warm),var(--sage))
    }
    .step-no{color:var(--sage); font-weight:700; font-size:.86rem; letter-spacing:.06em}
    .step-text{margin-top:10px; color:var(--muted)}

    .work-thumb{
      border-radius:20px; height:190px; border:1px solid rgba(98,80,64,.10); overflow:hidden; position:relative
    }
    .thumb-a{background:linear-gradient(135deg, rgba(184,142,105,.16), rgba(255,255,255,.92))}
    .thumb-b{background:linear-gradient(135deg, rgba(125,139,121,.18), rgba(255,255,255,.92))}
    .thumb-c{background:linear-gradient(135deg, rgba(184,142,105,.12), rgba(125,139,121,.16), rgba(255,255,255,.92))}
    .thumb-grid{
      position:absolute; inset:0; opacity:.34;
      background-image:
        linear-gradient(rgba(255,255,255,.5) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.5) 1px, transparent 1px);
      background-size:22px 22px
    }
    .thumb-card{
      position:absolute; left:18px; right:18px; bottom:18px; padding:14px 16px;
      border-radius:18px; background:rgba(255,255,255,.82); border:1px solid rgba(98,80,64,.10); backdrop-filter:blur(8px)
    }
    .thumb-card strong{display:block; font-size:.96rem}
    .thumb-card span{display:block; margin-top:4px; color:var(--muted); font-size:.82rem}
    .work-meta{display:flex; flex-wrap:wrap; gap:8px; margin-top:14px}
    .pill{
      padding:7px 10px; border-radius:999px; font-size:.78rem;
      background:rgba(255,255,255,.70); border:1px solid rgba(98,80,64,.10); color:var(--muted)
    }
    .work-body{margin-top:14px}
    .work-body h3{font-size:1.08rem}
    .work-body p{margin-top:8px; color:var(--muted)}
    .work-link{display:inline-flex; margin-top:16px; color:var(--warm-deep); font-weight:700}

    .snapshot-wrap{padding:28px; border-radius:var(--radius-xl)}
    .snapshot-wrap p{margin-top:10px; color:var(--muted)}
    .checklist{display:grid; gap:12px; margin-top:18px}
    .check{
      display:flex; gap:12px; align-items:flex-start; padding:14px 16px; border-radius:18px;
      background:rgba(255,255,255,.72); border:1px solid rgba(98,80,64,.10)
    }
    .check-mark{
      flex:0 0 auto; width:28px; height:28px; border-radius:50%;
      display:grid; place-items:center; background:linear-gradient(135deg, rgba(184,142,105,.18), rgba(125,139,121,.22));
      font-weight:800
    }
    .quote-card{
      display:flex; flex-direction:column; justify-content:space-between; padding:28px; border-radius:var(--radius-xl);
      position:relative; overflow:hidden
    }
    .quote-card::after{
      content:"“"; position:absolute; right:20px; bottom:-34px; font-size:9rem; color:rgba(184,142,105,.10); line-height:1; font-family:"Noto Serif TC",serif
    }
    .quote{font-family:"Noto Serif TC",serif; font-size:1.18rem; line-height:1.7}
    .quote-sub{margin-top:12px; color:var(--muted)}

    .contact-main,.contact-side{padding:28px; border-radius:var(--radius-xl)}
    .contact-actions{display:flex; flex-wrap:wrap; gap:12px; margin-top:22px}
    .contact-list{display:grid; gap:12px; margin-top:22px}
    .contact-item{
      display:flex; gap:14px; align-items:flex-start; padding:15px 16px; border-radius:18px;
      background:rgba(255,255,255,.72); border:1px solid rgba(98,80,64,.10)
    }
    .icon-badge{
      width:38px; height:38px; border-radius:14px; display:grid; place-items:center; font-weight:700;
      background:linear-gradient(135deg, rgba(184,142,105,.18), rgba(125,139,121,.18)); border:1px solid rgba(98,80,64,.10)
    }
    .contact-item strong{display:block; font-size:.92rem}
    .contact-item span{display:block; color:var(--muted); font-size:.9rem; margin-top:2px}
    .qr-card{
      display:grid; place-items:center; padding:20px; border-radius:22px; background:rgba(255,255,255,.72); border:1px solid rgba(98,80,64,.10)
    }
    .qr-card img{width:min(100%, 240px); border-radius:18px}
    .photo-credit{margin-top:12px; color:var(--muted); font-size:.84rem}

    .footer{padding:16px 0 calc(var(--dock) + 22px)}
    .footer-shell{
      padding:22px 24px; border-radius:24px; display:flex; align-items:center; justify-content:space-between; gap:14px
    }
    .footer-shell p{color:var(--muted); font-size:.92rem}

    .dock{
      position:fixed; left:50%; bottom:16px; transform:translateX(-50%);
      width:min(calc(100% - 24px), 680px); z-index:75; display:none;
      padding:10px; border-radius:999px; background:rgba(255,255,255,.84); border:1px solid rgba(98,80,64,.10);
      box-shadow:0 14px 34px rgba(70,48,27,.12); backdrop-filter:blur(14px)
    }
    .dock nav{display:grid; grid-template-columns:repeat(5,1fr); gap:8px}
    .dock a{
      padding:10px 6px; border-radius:999px; text-align:center; font-size:.82rem; color:var(--muted); transition:.2s ease
    }
    .dock a.active,.dock a:hover{background:rgba(248,243,237,.96); color:var(--ink)}

    .toast{
      position:fixed; left:50%; bottom:calc(var(--dock) + 20px); transform:translateX(-50%) translateY(20px);
      padding:12px 16px; border-radius:999px; background:rgba(47,41,37,.94); color:#fff; font-size:.9rem;
      opacity:0; pointer-events:none; transition:.25s ease; z-index:85
    }
    .toast.show{opacity:1; transform:translateX(-50%) translateY(0)}

    @media (max-width:1080px){
      .skills-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .process-grid,.portfolio-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .story-grid,.interests-grid,.snapshot-grid,.contact-grid{grid-template-columns:1fr}
    }
    @media (max-width:820px){
      .nav{display:none}
      .hero-shell{grid-template-columns:1fr}
      .stat-row{grid-template-columns:1fr}
      .dock{display:block}
      .footer{padding-bottom:calc(var(--dock) + 36px)}
    }
    @media (max-width:640px){
      .hero{padding-top:34px}
      .hero-card,.photo-card,.card,.snapshot-wrap,.quote-card,.contact-main,.contact-side{padding:22px}
      .skills-grid,.process-grid,.portfolio-grid{grid-template-columns:1fr}
      h1{font-size:2.5rem}
      .photo-card{padding:12px}
      .floating-note{position:static; margin:0 0 12px 0; max-width:none}
      .contact-actions,.hero-actions{flex-direction:column; align-items:stretch}
      .button,.ghost-button,.copy-button{width:100%}
      .footer-shell{flex-direction:column; align-items:flex-start}
    }
  </style>
</head>
<body>
  <div class="progress" aria-hidden="true"></div>

  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#top" aria-label="回到首頁">
        <div class="brand-mark">子</div>
        <div>
          <div class="brand-name">蘇子涵｜Zihan Su</div>
          <div class="brand-sub">資訊管理系・大一・一頁式個人網站</div>
        </div>
      </a>
      <nav class="nav" aria-label="主導覽">
        <a href="#about">About</a>
        <a href="#skills">Skills</a>
        <a href="#process">Process</a>
        <a href="#works">Works</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="container hero-shell">
        <div class="hero-card glass">
          <div class="eyebrow"><span class="dot"></span> Personal website / portfolio page</div>
          <h1>蘇子涵<br>把資訊整理，也把生活感留下來。</h1>
          <p class="hero-subtitle">我是資訊管理系大一學生，喜歡用數位工具把想法整理清楚，也喜歡在烘焙、煮飯與閱讀裡，慢慢長出自己的節奏與風格。</p>
          <p class="hero-note">這個網站不是只放資料，而是把「我是誰、我正在學什麼、我想成為怎樣的人」用更清楚的方式呈現出來。</p>

          <div class="hero-actions">
            <a class="button" href="#works">查看作品區</a>
            <a class="ghost-button" href="#contact">聯絡方式</a>
          </div>

          <div class="hero-chips">
            <span class="chip">資訊管理系</span>
            <span class="chip">大一學生</span>
            <span class="chip">文青・乾淨・溫柔</span>
            <span class="chip">AI 協作</span>
          </div>

          <div class="stat-row">
            <div class="stat">
              <strong>01</strong>
              <span>以單頁方式整合個人介紹、作品與聯絡資訊</span>
            </div>
            <div class="stat">
              <strong>02</strong>
              <span>將 AI 協作流程轉成可閱讀、可展示的成果頁</span>
            </div>
            <div class="stat">
              <strong>03</strong>
              <span>保留學生感與真實感，不做過度商業化包裝</span>
            </div>
          </div>
        </div>

        <aside class="photo-card glass" aria-label="個人照片與定位">
          <div class="floating-note">
            <small>Website note</small>
            <p>這一版已加入本人照片，讓網站從文案頁升級成更完整的個人展示頁。</p>
          </div>
          <div class="photo-frame">
            <img src="profile-focus.jpg" alt="蘇子涵的個人照片" />
            <div class="photo-panel">
              <div class="title">Zihan Su</div>
