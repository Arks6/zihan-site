  <div class="toast" id="toast" role="status" aria-live="polite">已複製 IG 帳號：zihan_1123_</div>

  <script>
    const sections = [...document.querySelectorAll('main section[id]')];
    const topTarget = document.querySelector('#top');
    const navLinks = [...document.querySelectorAll('.nav a, .dock a')];
    const progress = document.querySelector('.progress');
    const toast = document.getElementById('toast');

    function setActiveLink() {
      const offset = window.scrollY + 140;
      let currentId = '';
      for (const section of sections) {
        if (offset >= section.offsetTop) currentId = section.id;
      }
      navLinks.forEach(link => {
        const match = link.getAttribute('href') === `#${currentId}`;
        link.classList.toggle('active', match);
      });
    }

    function setProgress() {
      const scrollTop = window.scrollY;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = max > 0 ? (scrollTop / max) * 100 : 0;
      document.documentElement.style.setProperty('--progress', ratio + '%');
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add('show');
      clearTimeout(window.__toastTimer);
      window.__toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
    }

    function openInstagram(event, url) {
      if (event) event.preventDefault();
      const opened = window.open(url, '_blank', 'noopener,noreferrer');
      if (!opened) window.location.href = url;
    }

    async function copyIG() {
      const text = 'zihan_1123_';
      try {
        await navigator.clipboard.writeText(text);
        showToast('已複製 IG 帳號：' + text);
      } catch (err) {
        const input = document.createElement('input');
        input.value = text;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        input.remove();
        showToast('已複製 IG 帳號：' + text);
      }
    }

    setActiveLink();
    setProgress();
    window.addEventListener('scroll', () => {
      setActiveLink();
      setProgress();
    }, { passive: true });

    window.openInstagram = openInstagram;
    window.copyIG = copyIG;
  </script>
</body>
